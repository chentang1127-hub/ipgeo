# IPGeo Configuration

# Environment: development | production | test
IPGEO_ENVIRONMENT=development

# Server
IPGEO_HOST=0.0.0.0
IPGEO_PORT=8000
IPGEO_WORKERS=4

# Redis (for billing + rate limiting + key store)
# Leave default for dev mode (in-memory fallback)
IPGEO_REDIS_URL=redis://localhost:6379/0

# MaxMind license key (for weekly DB downloads)
IPGEO_MAXMIND_LICENSE_KEY=your-license-key-here

# Database file paths
IPGEO_CITY_DB_PATH=data/GeoLite2-City.mmdb
IPGEO_ASN_DB_PATH=data/GeoLite2-ASN.mmdb

# Paid GeoIP2 databases (higher precision, for Pro+/Business/Enterprise plans)
IPGEO_GEOIP2_CITY_DB_PATH=
IPGEO_GEOIP2_ASN_DB_PATH=

# Admin token (for /v1/admin/keys management)
IPGEO_ADMIN_TOKEN=change-me-in-production

# Rate limit window in seconds (default: 60)
IPGEO_RATELIMIT_WINDOW=60

# ---------------------------------------------------------------------------
# Lemon Squeezy Billing (required for paid plans)
# ---------------------------------------------------------------------------
# Get your API key at: https://app.lemonsqueezy.com/settings/api
# Webhook secret: set a random string in your store's webhook settings.
#
# Store ID: find it in your LS dashboard URL or Settings → API.
# Variant IDs: create products/variants at https://app.lemonsqueezy.com/products
#   then paste their numeric IDs below.
IPGEO_LEMONSQUEEZY_API_KEY=eyJ0eXAiOiJKV1QiLCJhbGciOiJSUzI1NiJ9...
IPGEO_LEMONSQUEEZY_WEBHOOK_SECRET=7fe93befbb1b40489f640e816152e718
IPGEO_LEMONSQUEEZY_STORE_ID=408304

# Lemon Squeezy variant ID → IPGeo plan mapping
# IPGEO_LEMONSQUEEZY_VARIANT_PLAN_MAP='{"1794238":"free","1794256":"starter","1794262":"pro","1794265":"business"}'

# Webhook is already configured in LS dashboard:
#   URL:  https://api.getipgeo.com/v1/webhooks/lemonsqueezy
#   ID:   110771
#   Events: order_created, subscription_*
