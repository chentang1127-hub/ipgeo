# IPGeo Configuration

# Environment: development | production | test
IPGEO_ENVIRONMENT=development

# Server
IPGEO_HOST=0.0.0.0
IPGEO_PORT=8000
IPGEO_WORKERS=4

# Redis (for billing + rate limiting + key store)
# Leave default for dev mode (in-memory fallback)
IPGEO_REDIS_URL=redis://localhost:6379/0

# MaxMind license key (for weekly DB downloads)
IPGEO_MAXMIND_LICENSE_KEY=your-license-key-here

# Database file paths
IPGEO_CITY_DB_PATH=data/GeoLite2-City.mmdb
IPGEO_ASN_DB_PATH=data/GeoLite2-ASN.mmdb

# Paid GeoIP2 databases (higher precision, for Pro+/Business/Enterprise plans)
IPGEO_GEOIP2_CITY_DB_PATH=
IPGEO_GEOIP2_ASN_DB_PATH=

# Admin token (for /v1/admin/keys management)
IPGEO_ADMIN_TOKEN=change-me-in-production

# Rate limit window in seconds (default: 60)
IPGEO_RATELIMIT_WINDOW=60

# ---------------------------------------------------------------------------
# Paddle Billing (required for paid plans)
# ---------------------------------------------------------------------------
# Sandbox: https://sandbox-vendors.paddle.com
# Live:    https://vendors.paddle.com
IPGEO_PADDLE_SANDBOX=true
IPGEO_PADDLE_API_KEY=
IPGEO_PADDLE_WEBHOOK_SECRET=

# Paddle price ID → IPGeo plan mapping
# (defaults shown; override with JSON if needed)
# IPGEO_PADDLE_PRICE_PLAN_MAP='{"pri_xxx":"free","pri_yyy":"starter",...}'
